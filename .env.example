# Konfigurasi Environment - Sistem Deteksi Kebakaran
# Copy file ini ke .env dan sesuaikan nilainya.
# Variabel yang dikomentari (#) bersifat OPSIONAL — nilai default sudah
# ditangani di kode, cukup uncomment kalau mau override.

# --- Keamanan ---
SECRET_KEY=pbl-sem-6-rahasia-banget

# --- Telegram Notifikasi ---
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
CHAT_ID=YOUR_CHAT_ID_HERE

# --- Chatbot Model ---
# PENTING: nama file HARUS mengandung "qwen", "gemma", atau "llama"
# agar chatbot.py otomatis memilih format prompt yang benar.
CHATBOT_MODEL_PATH=models/qwen2.5-1.5b-k3.gguf

# --- RAG: Embedding & Re-ranker (opsional) ---
# Ganti embedding = WAJIB hapus chroma_db_native/ lalu re-ingest (dimensi beda).
# Kosongkan RERANKER_MODEL_NAME untuk skip re-ranker (hemat ~568MB RAM).
#EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
#RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# --- RAG: Bobot Hybrid Search (opsional, total = 1.0) ---
#RAG_BM25_WEIGHT=0.4
#RAG_DENSE_WEIGHT=0.6

# --- RAG: Parameter Retrieval (opsional) ---
#RAG_TOP_K_RETRIEVE=10
#RAG_TOP_K_FINAL=3
#RAG_CONTEXT_MAX_CHARS=900
#BM25_INDEX_PATH=models/bm25_index.pkl

# --- LSTM Anomaly (opsional) ---
#LSTM_MODEL_PATH=models/lstm_anomaly.keras
#LSTM_SCALER_PATH=models/lstm_scaler.pkl
#LSTM_META_PATH=models/lstm_threshold.json

# --- Feedback Storage (opsional) ---
#FEEDBACK_DB_PATH=data/feedback.db

# --- API Key Synthetic Data (opsional) ---
# HANYA dipakai scripts/generate_synthetic.py — bukan untuk runtime server.
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
